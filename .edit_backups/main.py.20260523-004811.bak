import json
import os
import re
from flask import Flask, render_template, request, jsonify
from world_manager import WorldManager
from llm_interface import LLMInterface
import system_prompts
from llm_contracts import (
    ContractError,
    validate_genesis_response,
    validate_room_response,
    validate_state_manager_response,
    validate_turn_response,
)

APP_STATE_FILE = "app_state.json"

def load_app_state():
    if os.path.exists(APP_STATE_FILE):
        try:
            with open(APP_STATE_FILE, "r", encoding="utf-8") as f:
                data = json.load(f)
                return data if isinstance(data, dict) else {}
        except Exception:
            return {}
    return {}


def save_app_state(**updates):
    state = load_app_state()
    state.update({k: v for k, v in updates.items() if v is not None})
    with open(APP_STATE_FILE, "w", encoding="utf-8") as f:
        json.dump(state, f, indent=2)
    return state


def get_startup_world_name():
    state = load_app_state()
    active_save = state.get("active_save")
    if isinstance(active_save, str) and active_save.endswith(".json"):
        candidate = active_save[:-5]
        if os.path.exists(os.path.join("saves", active_save)):
            return candidate
    return None


app = Flask(__name__)
world = WorldManager(get_startup_world_name())
ai = LLMInterface()
audit_chat_history = []

def log_system(msg):
    print(f"[SYSTEM] {msg}", flush=True)

@app.route('/update-files', methods=['POST'])
def update_files():
    if request.headers.get('X-Secret-Key') != "JosieSecret123":
        return "Unauthorized", 401

    content = request.get_data(as_text=True)
    if not content:
        return jsonify({"status": "error", "message": "No data"}), 400

    updated_files = []
    # Use a trick to prevent the regex from matching itself in the source code
    marker_regex = r'---FILE' + r':(.*?)---'
    parts = re.split(marker_regex, content)

    for i in range(1, len(parts), 2):
        filepath = parts[i].strip()
        code = parts[i+1].strip()

        folder = os.path.dirname(filepath)
        if folder and not os.path.exists(folder):
            os.makedirs(folder, exist_ok=True)

        with open(filepath, 'w', encoding='utf-8') as f:
            f.write(code)
        updated_files.append(filepath)

    return jsonify({"status": "success", "updated": updated_files})

@app.route('/')
def index():
    log_system("Frontend Connected")
    return render_template('index.html')

@app.route('/get_state', methods=['GET'])
def get_state():
    if not world.is_initialized():
        log_system("State requested: UNINITIALIZED")
        return jsonify({"response": "INITIALIZING_GENESIS", "state": None})

    room = world.get_current_room()
    return jsonify({"response": f"### {room['name']}\n{world.describe_room(room)}", "state": get_ui_state()})


def _safe_filename(name):
    if not isinstance(name, str):
        return None
    base = os.path.basename(name.strip())
    if not base or base != name.strip():
        return None
    return base


def _read_json_file(path):
    try:
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return None


def _save_summary(filename):
    path = os.path.join("saves", filename)
    data = _read_json_file(path) or {}
    room_id = data.get("player", {}).get("current_room")
    room = data.get("rooms", {}).get(room_id, {}) if room_id else {}
    stat = os.stat(path)
    meta = data.get("meta", {}) if isinstance(data, dict) else {}
    return {
        "file": filename,
        "world_name": meta.get("world_name") or (filename[:-5] if filename.endswith(".json") else filename),
        "active_lore_file": meta.get("active_lore_file"),
        "has_lore_snapshot": bool(meta.get("lore_text_snapshot")),
        "current": filename == os.path.basename(world.save_path),
        "initialized": bool(data),
        "location": room.get("name", "Unknown"),
        "total_tokens": meta.get("total_tokens", 0),
        "modified": stat.st_mtime,
    }


LOREBOOK_TEMPLATE = """WORLD_NAME: new_world

TITLE:
A short title for this scenario.

GENRE / MODE:
Examples: cozy slice of life, dark fantasy, erotic romance, survival horror, mystery, comedy.

PLAYER CHARACTER:
Describe who the player is, what they look like, what they are wearing, and what matters about them.

STARTING SITUATION:
Describe what is happening at the first moment of play.

STARTING LOCATION:
Describe the first room/location and nearby exits or obvious paths.

IMPORTANT CHARACTERS:
List key NPCs, their relationships to the player, where they begin, what they want, and how they speak.

IMPORTANT OBJECTS:
List objects that should exist at the start or matter later.

WORLD RULES:
Describe magic, technology, social rules, safety constraints, supernatural rules, or other setting logic.

TONE AND STYLE:
Describe the desired prose style, pacing, intensity, and emotional/sexual tone.

BOUNDARIES / DO NOT INCLUDE:
Optional. List anything the scenario should avoid.

LONG-TERM DIRECTION:
Optional. Describe likely story arcs, secrets, conflicts, or goals.
"""


def _list_lore_books():
    entries = []
    if os.path.exists("LoreBooks"):
        for filename in sorted(os.listdir("LoreBooks")):
            if filename.startswith("."):
                continue
            path = os.path.join("LoreBooks", filename)
            if os.path.isfile(path):
                entries.append({"file": filename})
    return entries


def _safe_lorebook_filename(name):
    if not isinstance(name, str):
        return None
    base = os.path.basename(name.strip())
    if not base or base != name.strip():
        return None
    if not re.match(r'^[A-Za-z0-9_. -]+$', base):
        return None
    if not base.lower().endswith((".txt", ".md")):
        base += ".txt"
    return base


def _world_name_from_lore_filename(filename):
    base = os.path.splitext(filename)[0].lower()
    clean = "".join(c if c.isalnum() else "_" for c in base)
    clean = re.sub(r"_+", "_", clean).strip("_")
    return clean or "new_world"


@app.route('/save_manager', methods=['GET'])
def save_manager():
    saves = []
    if os.path.exists("saves"):
        for filename in sorted(os.listdir("saves")):
            if filename.endswith(".json"):
                saves.append(_save_summary(filename))
    app_state = load_app_state()
    return jsonify({
        "current_save": os.path.basename(world.save_path),
        "current_world": world.world_name,
        "active_lore_file": app_state.get("active_lore_file"),
        "saves": saves,
        "lore_books": _list_lore_books(),
    })


@app.route('/load_save', methods=['POST'])
def load_save():
    global world
    payload = request.get_json(silent=True) or {}
    filename = _safe_filename(payload.get("file"))
    if not filename or not filename.endswith(".json"):
        return jsonify({"status": "error", "message": "Invalid save file."}), 400

    path = os.path.join("saves", filename)
    if not os.path.exists(path):
        return jsonify({"status": "error", "message": "Save file not found."}), 404

    data = _read_json_file(path)
    if not isinstance(data, dict):
        return jsonify({"status": "error", "message": "Save file could not be read."}), 400

    world.world_name = filename[:-5]
    world.save_path = path
    world.data = data
    world.ensure_schema()
    world.data.setdefault("meta", {})["world_name"] = world.world_name
    restore_lore_txt_from_save_if_possible(world.data)
    save_app_state(active_save=filename, active_world=world.world_name, active_lore_file=world.data.get("meta", {}).get("active_lore_file"))
    world.save_game()

    room = world.get_current_room()
    return jsonify({
        "status": "success",
        "response": f"Loaded **{filename}**.\n\n### {room['name']}\n{world.describe_room(room)}",
        "state": get_ui_state(),
    })


def _write_lore_from_lorebook(filename):
    safe = _safe_filename(filename)
    if not safe:
        raise ValueError("Invalid lore file.")
    path = os.path.join("LoreBooks", safe)
    if not os.path.exists(path) or not os.path.isfile(path):
        raise FileNotFoundError("LoreBooks entry not found.")
    with open(path, "r", encoding="utf-8") as f:
        lore_text = f.read()
    with open("lore.txt", "w", encoding="utf-8") as f:
        f.write(lore_text)
    return safe


def clear_runtime_debug_logs():
    for path in ("last_turn_debug.txt", "debug_log.txt"):
        try:
            if os.path.exists(path):
                os.remove(path)
        except Exception:
            pass


@app.route('/read_lorebook', methods=['POST'])
def read_lorebook():
    payload = request.get_json(silent=True) or {}
    filename = _safe_filename(payload.get("file"))
    if not filename:
        return jsonify({"status": "error", "message": "Invalid lorebook filename."}), 400

    path = os.path.join("LoreBooks", filename)
    if not os.path.exists(path) or not os.path.isfile(path):
        return jsonify({"status": "error", "message": "Lorebook not found."}), 404

    try:
        with open(path, "r", encoding="utf-8") as f:
            return jsonify({"status": "success", "file": filename, "content": f.read()})
    except Exception as e:
        return jsonify({"status": "error", "message": f"Could not read lorebook: {str(e)}"}), 400


@app.route('/update_lorebook', methods=['POST'])
def update_lorebook():
    payload = request.get_json(silent=True) or {}
    filename = _safe_filename(payload.get("file"))
    content = payload.get("content")

    if not filename:
        return jsonify({"status": "error", "message": "Invalid lorebook filename."}), 400
    if not isinstance(content, str):
        return jsonify({"status": "error", "message": "Lorebook content must be text."}), 400

    path = os.path.join("LoreBooks", filename)
    if not os.path.exists(path) or not os.path.isfile(path):
        return jsonify({"status": "error", "message": "Lorebook not found."}), 404

    try:
        with open(path, "w", encoding="utf-8") as f:
            f.write(content)
        return jsonify({"status": "success", "file": filename})
    except Exception as e:
        return jsonify({"status": "error", "message": f"Could not update lorebook: {str(e)}"}), 400


@app.route('/map_state', methods=['GET'])
def map_state():
    if not world.is_initialized():
        return jsonify({"status": "error", "message": "World is not initialized."}), 400

    rooms = []
    for rid, room in world.data.get("rooms", {}).items():
        if not isinstance(room, dict):
            continue
        rooms.append({
            "id": rid,
            "name": room.get("name") or "Unknown",
            "visited": bool(room.get("visited")),
            "current": rid == world.data.get("player", {}).get("current_room"),
            "description": room.get("base_description") or room.get("description") or "",
            "exits": room.get("exits", {}),
            "items": [
                world.data["items"][iid]["name"]
                for iid in room.get("items", [])
                if iid in world.data.get("items", {})
            ],
            "characters": [
                world.data["characters"][cid]["name"]
                for cid in room.get("characters", [])
                if cid in world.data.get("characters", {})
            ],
        })

    return jsonify({
        "status": "success",
        "current_room": world.data.get("player", {}).get("current_room"),
        "rooms": rooms,
    })


@app.route('/create_lorebook', methods=['POST'])
def create_lorebook():
    payload = request.get_json(silent=True) or {}
    filename = _safe_lorebook_filename(payload.get("file"))
    if not filename:
        return jsonify({"status": "error", "message": "Invalid lorebook filename."}), 400

    if not os.path.exists("LoreBooks"):
        os.makedirs("LoreBooks", exist_ok=True)

    target_path = os.path.join("LoreBooks", filename)
    if os.path.exists(target_path):
        return jsonify({"status": "error", "message": "A lorebook with that name already exists."}), 400

    source_file = payload.get("source_file")
    try:
        if source_file:
            source_safe = _safe_filename(source_file)
            if not source_safe:
                return jsonify({"status": "error", "message": "Invalid source lorebook."}), 400
            source_path = os.path.join("LoreBooks", source_safe)
            if not os.path.exists(source_path):
                return jsonify({"status": "error", "message": "Source lorebook not found."}), 404
            with open(source_path, "r", encoding="utf-8") as f:
                content = f.read()
        else:
            content = LOREBOOK_TEMPLATE.replace("WORLD_NAME: new_world", f"WORLD_NAME: {_world_name_from_lore_filename(filename)}", 1)

        with open(target_path, "w", encoding="utf-8") as f:
            f.write(content)

        return jsonify({"status": "success", "file": filename})
    except Exception as e:
        return jsonify({"status": "error", "message": f"Could not create lorebook: {str(e)}"}), 400


@app.route('/new_game', methods=['POST'])
def new_game():
    global world
    payload = request.get_json(silent=True) or {}
    lore_file = payload.get("lore_file")

    try:
        active_lore_file = None
        if lore_file:
            active_lore_file = _write_lore_from_lorebook(lore_file)

        clear_runtime_debug_logs()
        world = WorldManager()
        world.data = None
        save_app_state(
            active_save=os.path.basename(world.save_path),
            active_world=world.world_name,
            active_lore_file=active_lore_file,
        )
        return reset_game()
    except Exception as e:
        log_system(f"New game failed: {str(e)}")
        return jsonify({"status": "error", "message": f"New game failed: {str(e)}"}), 400

@app.route('/reset', methods=['POST'])
def reset_game():
    log_system("HARD RESET TRIGGERED")
    world.hard_reset()
    try:
        log_system("Calling Genesis AI...")
        lore_text = get_active_lore_text()
        genesis_data = validate_genesis_response(ai.generate_genesis(lore_text))

        log_system("Initializing World DB...")
        intro = world.initialize_world(genesis_data)
        app_state = load_app_state()
        world.data.setdefault("meta", {})["world_name"] = world.world_name
        world.data.setdefault("meta", {})["active_lore_file"] = app_state.get("active_lore_file")
        world.data.setdefault("meta", {})["lore_text_snapshot"] = lore_text
        save_app_state(active_save=os.path.basename(world.save_path), active_world=world.world_name, active_lore_file=app_state.get("active_lore_file"))
        world.save_game()

        room = world.get_current_room()
        log_system("World Created Successfully.")
        return jsonify({
            "response": f"{intro}\n\n### {room['name']}\n{world.describe_room(room)}",
            "state": get_ui_state()
        })
    except ContractError as e:
        log_system(f"Genesis response rejected: {str(e)}")
        return jsonify({"response": f"Genesis Failed: {str(e)}", "state": None})
    except Exception as e:
        log_system(f"Genesis Failed: {str(e)}")
        return jsonify({"response": f"Genesis Failed: {str(e)}", "state": None})

@app.route('/command', methods=['POST'])
def handle_command():
    if not world.is_initialized(): return jsonify({"response": "Uninitialized."})

    payload = request.get_json(silent=True) or {}
    user_input = payload.get('input', '').strip()
    clean = user_input.lower().strip()
    if not user_input: return jsonify({"response": ""})

    log_system(f"Cmd: {user_input}")

    pending = world.get_pending_ambiguity()
    if pending:
        resolved = world.resolve_pending_ambiguity(user_input)
        if not resolved:
            return jsonify({
                "response": world.format_ambiguity_prompt(pending.get('matches', [])),
                "state": get_ui_state(),
                "turn_report": {
                    "warnings": ["The ambiguity answer did not match any listed option."],
                    "pending_ambiguity": pending,
                },
            })
        world.clear_pending_ambiguity()
        user_input = f"{pending.get('original_input', user_input)} [Resolved target: {resolved.get('name')} (ID: {resolved.get('id')})]"
        clean = user_input.lower().strip()

    # DISAMBIGUATION CHECK
    if len(clean.split()) > 1:
        noun = clean.split()[-1]
        if noun not in ['me', 'self', 'myself', 'player']:
            matches = world.find_item_matches(noun, visible_only=True)
            options = []
            seen = set()
            for iid, item in matches:
                if iid in seen:
                    continue
                seen.add(iid)
                options.append({"id": iid, "name": item.get("name", iid)})

            if len(options) > 1:
                world.set_pending_ambiguity(user_input, noun, options)
                return jsonify({
                    "response": world.format_ambiguity_prompt(options),
                    "state": get_ui_state(),
                    "turn_report": {
                        "warnings": [f"The reference '{noun}' matched multiple visible items."],
                        "pending_ambiguity": world.get_pending_ambiguity(),
                    },
                })

    # Deterministic Checks
    if clean in ['help', '/help', '?']:
        help_text = (
            "### Z-MACHINE COMMAND GUIDE\n\n"
            "**Exploration:**\n"
            "- `look` (or `l`): Describe your current surroundings.\n"
            "- `north`, `south`, `east`, `west`, `up`, `down` (or `n`, `s`, `e`, `w`, `u`, `d`): Move through the world.\n"
            "- `examine [object]` (or `x [object]`): Look closely at something or yourself.\n\n"
            "**Inventory:**\n"
            "- `inventory` (or `i`): List what you are carrying and wearing.\n"
            "- `take [object]`: Pick something up.\n"
            "- `drop [object]`: Set something down.\n"
            "- `wear [object]`: Put on clothing or armor.\n"
            "- `remove [object]`: Take off clothing.\n\n"
            "**System Commands:**\n"
            "- `/models`: List available Venice AI models.\n"
            "- `/model [ID]`: Switch the AI engine to a different model.\n"
            "- `/reset`: Wipe the world and regenerate from `lore.txt`.\n"
            "- **DATA PAD (HUD):** Use the sidebar to track metrics and use **THE MATRIX** (God Mode) to edit reality.\n\n"
            "**Interaction:**\n"
            "You can type almost anything! The AI Dungeon Master will interpret your intent. "
            "Try: *'read the dusty journal'*, *'knock on the iron door'*, or *'search the desk'*"
        )
        return jsonify({"response": help_text, "state": get_ui_state()})

    if clean in ['i', 'inv', 'inventory']:
        p = world.data['player']
        items = [world.data['items'][i]['name'] for i in p['inventory'] if i in world.data['items']]
        worn = [world.data['items'][i]['name'] for i in p.get('worn', []) if i in world.data['items']]
        res = []
        if items: res.append("**Carrying:**\n" + "\n".join([f"- {n}" for n in items]))
        if worn: res.append("**Wearing:**\n" + "\n".join([f"- {n}" for n in worn]))
        return jsonify({"response": "\n\n".join(res) if res else "Carrying nothing.", "state": get_ui_state()})

    if clean in ['l', 'look']:
        room = world.get_current_room()
        return jsonify({"response": f"### {room['name']}\n{world.describe_room(room)}", "state": get_ui_state()})

    if clean.startswith('x ') or clean.startswith('examine '):
        target = clean.split(' ', 1)[1].strip()
        if target in ['me', 'self', 'myself', 'player']:
            return jsonify({"response": world.describe_player(), "state": get_ui_state()})
        item = world.get_item_by_name(target)
        if item: return jsonify({"response": item['description'], "state": get_ui_state()})

    # Movement Logic
    status, target, prev_id = world.move_player(user_input)
    if status == "ok":
        room = world.get_room(target)
        return jsonify({"response": f"### {room['name']}\n{world.describe_room(room)}", "state": get_ui_state()})

    if status == "generate":
        prev = world.get_room(prev_id)
        thread = world.get_narrative_history()
        blueprint = world.data.get('blueprint', '')
        map_sum = world.get_map_summary()

        log_system("Generating New Room...")
        try:
            new_data = validate_room_response(ai.generate_room(prev, user_input, thread, blueprint, map_sum, get_active_lore_text()))
        except ContractError as e:
            world.data['player']['current_room'] = prev_id
            world.save_game()
            log_system(f"Room generation rejected: {str(e)}")
            return jsonify({"response": f"Room generation failed: {str(e)}", "state": get_ui_state()})

        world.create_room_from_stub(target, new_data)
        room = world.get_room(target)
        return jsonify({"response": f"### {room['name']}\n{world.describe_room(room)}", "state": get_ui_state()})

    if status == "error" and "Invalid direction" in target:
        log_system("Handing off to DM AI...")
        return process_ai_turn(user_input)

    return jsonify({"response": target, "state": get_ui_state()})

def _read_text_file(path, max_chars=60000):
    try:
        if not os.path.exists(path):
            return ""
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
        return text[:max_chars]
    except Exception:
        return ""


def _read_lorebook_text(filename):
    safe = _safe_filename(filename)
    if not safe:
        return ""
    return _read_text_file(os.path.join("LoreBooks", safe), max_chars=200000)


def get_active_lore_text():
    if world.is_initialized():
        meta = world.data.get("meta", {}) if isinstance(world.data, dict) else {}
        snapshot = meta.get("lore_text_snapshot")
        if isinstance(snapshot, str) and snapshot.strip():
            return snapshot

        active_lore_file = meta.get("active_lore_file")
        if active_lore_file:
            lore_text = _read_lorebook_text(active_lore_file)
            if lore_text.strip():
                world.data.setdefault("meta", {})["lore_text_snapshot"] = lore_text
                world.save_game()
                return lore_text

    app_state = load_app_state()
    active_lore_file = app_state.get("active_lore_file")
    if active_lore_file:
        lore_text = _read_lorebook_text(active_lore_file)
        if lore_text.strip():
            return lore_text

    return _read_text_file("lore.txt", max_chars=200000)


def restore_lore_txt_from_save_if_possible(save_data):
    meta = save_data.get("meta", {}) if isinstance(save_data, dict) else {}
    lore_text = meta.get("lore_text_snapshot")
    if not isinstance(lore_text, str) or not lore_text.strip():
        active_lore_file = meta.get("active_lore_file")
        lore_text = _read_lorebook_text(active_lore_file) if active_lore_file else ""

    if isinstance(lore_text, str) and lore_text.strip():
        with open("lore.txt", "w", encoding="utf-8") as f:
            f.write(lore_text)
        save_data.setdefault("meta", {})["lore_text_snapshot"] = lore_text
        return True

    return False


def build_audit_context():
    if not world.is_initialized():
        return "WORLD IS NOT INITIALIZED."

    sections = []
    sections.append("# ACTIVE LORE\n" + get_active_lore_text())
    sections.append("# WORLD SAVE JSON\n" + json.dumps(world.data, ensure_ascii=False, indent=2))
    sections.append("# CURRENT CONTEXT DUMP SENT TO MAIN LLM\n" + world.get_context_dump())
    sections.append("# NARRATIVE MEMORY\n" + world.get_narrative_history())
    sections.append("# MAP SUMMARY\n" + world.get_map_summary())
    sections.append("# PROMPT: GENESIS\n" + system_prompts.PROMPT_GENESIS)
    sections.append("# PROMPT: ARCHITECT\n" + system_prompts.PROMPT_ARCHITECT)
    sections.append("# PROMPT: DM\n" + system_prompts.PROMPT_DM)
    sections.append("# PROMPT: FIXER\n" + system_prompts.PROMPT_FIXER)
    sections.append(
        "# DEBUG NOTE\n"
        "Global debug_log.txt and last_turn_debug.txt are intentionally excluded from this audit context because they can contain prior saves/worlds. "
        "Use the current save JSON, current context dump, map summary, active lore, and narrative memory as the authoritative audit source."
    )
    return "\n\n".join(sections)


@app.route('/start_audit', methods=['POST'])
def start_audit():
    global audit_chat_history
    if not world.is_initialized():
        return jsonify({"status": "error", "message": "World is not initialized."}), 400

    context = build_audit_context()
    result = ai.audit_game(context)
    if result.get("error"):
        return jsonify({"status": "error", "message": result.get("narrative", "Audit failed.")}), 400

    response = result.get("response") or result.get("narrative") or json.dumps(result, indent=2)
    audit_chat_history = [
        {"role": "user", "content": "Please audit the current game state."},
        {"role": "assistant", "content": response},
    ]
    return jsonify({"status": "success", "response": response})


@app.route('/continue_audit', methods=['POST'])
def continue_audit():
    global audit_chat_history
    payload = request.get_json(silent=True) or {}
    message = payload.get("message", "").strip()
    if not message:
        return jsonify({"status": "error", "message": "Message is required."}), 400

    audit_chat_history.append({"role": "user", "content": message})
    result = ai.continue_audit(audit_chat_history)
    if result.get("error"):
        return jsonify({"status": "error", "message": result.get("narrative", "Audit chat failed.")}), 400

    response = result.get("response") or result.get("narrative") or json.dumps(result, indent=2)
    audit_chat_history.append({"role": "assistant", "content": response})
    return jsonify({"status": "success", "response": response})


def run_genesis_state_manager_pass(genesis_data, intro_text):
    narrator_output = {
        "narrative": (
            f"{genesis_data.get('intro_text', '')}\n\n"
            f"STARTING ROOM: {genesis_data.get('starting_room_name', '')}\n"
            f"{genesis_data.get('starting_room_description', '')}\n\n"
            f"PLAYER DESCRIPTION:\n{genesis_data.get('player_description', '')}"
        ),
        "narrative_summary_update": genesis_data.get("narrative_thread", ""),
    }

    try:
        state_outcome = validate_state_manager_response(
            ai.compile_state_from_narrative(
                "GENESIS INITIALIZATION: compile the opening narrative, starting room, player description, and physically present/absent starting facts into missing state updates.",
                narrator_output,
                world.get_context_dump(),
                get_state_manager_tool_contract(),
            )
        )
    except ContractError as e:
        log_system(f"Genesis State Manager pass rejected: {str(e)}")
        return {
            "state_updates": [],
            "warnings": [f"Genesis State Manager rejected: {str(e)}"],
            "unsupported_claims": [],
        }

    outcome = {
        "narrative": intro_text,
        "narrative_summary_update": state_outcome.get("narrative_summary_update") or genesis_data.get("narrative_thread", ""),
        "state_updates": state_outcome.get("state_updates", []),
        "state_manager_warnings": state_outcome.get("warnings", []),
        "unsupported_claims": state_outcome.get("unsupported_claims", []),
    }
    world.apply_outcome(outcome)
    return outcome


@app.route('/models', methods=['GET'])
def list_models():
    models = ai.get_available_models()
    return jsonify(models)

@app.route('/set_model', methods=['POST'])
def set_model():
    payload = request.get_json(silent=True) or {}
    model_id = payload.get('model')
    if model_id:
        ai.model = model_id
        return jsonify({"status": "success", "model": model_id})
    return jsonify({"status": "error"}), 400

def get_state_manager_tool_contract():
    return (
        "Allowed tools: create_entity, describe_entity, move_entity, set_entity_visibility, "
        "create_character, update_character, move_character, update_player, append_memory. "
        "Do not invent room/edit-exit tools yet; put those facts in unsupported_claims. "
        "Do not duplicate existing entities, characters, or memory entries already represented in the authoritative world."
    )


def _turn_report_from_outcome(outcome):
    tool_results = outcome.get('tool_results', []) if isinstance(outcome, dict) else []
    warnings = []
    for result in tool_results:
        status = result.get('status') if isinstance(result, dict) else None
        if status and status not in ('accepted', 'accepted_with_repair', 'ignored_duplicate'):
            warnings.append(f"{result.get('tool', 'tool')} returned {status} for {result.get('target', result.get('entity_id', 'unknown'))}.")
    warnings.extend(outcome.get('state_manager_warnings', []) if isinstance(outcome.get('state_manager_warnings'), list) else [])
    warnings.extend([
        f"Unsupported state claim: {claim}"
        for claim in outcome.get('unsupported_claims', [])
    ] if isinstance(outcome.get('unsupported_claims'), list) else [])
    if outcome.get('state_manager_error'):
        warnings.append(f"State manager failed: {outcome.get('state_manager_error')}")
    return {
        "requested_tools": len(outcome.get('state_updates', [])) if isinstance(outcome.get('state_updates', []), list) else 0,
        "accepted_tools": sum(1 for result in tool_results if isinstance(result, dict) and result.get('status') in ('accepted', 'accepted_with_repair')),
        "rejected_or_ignored_tools": sum(1 for result in tool_results if isinstance(result, dict) and result.get('status') not in ('accepted', 'accepted_with_repair')),
        "warnings": warnings,
        "tool_results": tool_results,
    }


def process_ai_turn(inp):
    # Check for System Notifications (from previous syncs not yet popped)
    msgs = world.pop_system_notifications()
    full_input = inp
    if msgs:
        sys_msg = "\n\n".join([f"[SYSTEM NOTICE: {m}]" for m in msgs])
        full_input = f"{sys_msg}\n\nPLAYER ACTION: {inp}"

    thread = world.get_narrative_history()
    context_dump = world.get_context_dump()

    try:
        narrator_outcome = validate_turn_response(ai.process_turn(full_input, thread, context_dump, get_active_lore_text()))
    except ContractError as e:
        log_system(f"Narrator response rejected: {str(e)}")
        return jsonify({"response": f"AI turn failed: {str(e)}", "state": get_ui_state()})

    tool_contract = get_state_manager_tool_contract()

    try:
        state_outcome = validate_state_manager_response(
            ai.compile_state_from_narrative(full_input, narrator_outcome, context_dump, tool_contract)
        )
    except ContractError as e:
        log_system(f"State manager response rejected: {str(e)}")
        state_outcome = {
            "state_updates": [],
            "warnings": [],
            "unsupported_claims": [],
            "state_manager_error": str(e),
        }

    outcome = {
        "narrative": narrator_outcome.get("narrative", "..."),
        "narrative_summary_update": (
            state_outcome.get("narrative_summary_update")
            or narrator_outcome.get("narrative_summary_update")
            or ""
        ),
        "state_updates": state_outcome.get("state_updates", []),
        "state_manager_warnings": state_outcome.get("warnings", []),
        "unsupported_claims": state_outcome.get("unsupported_claims", []),
    }
    if state_outcome.get("state_manager_error"):
        outcome["state_manager_error"] = state_outcome["state_manager_error"]

    world.apply_outcome(outcome)
    world.record_turn(full_input, outcome)

    return jsonify({
        "response": outcome.get("narrative", "..."),
        "state": get_ui_state(),
        "turn_report": _turn_report_from_outcome(outcome),
    })

# --- GOD MODE ROUTES ---
@app.route('/get_god_state', methods=['GET'])
def get_god_state():
    return jsonify(world.get_god_state())

@app.route('/god_update', methods=['POST'])
def god_update():
    payload = request.get_json(silent=True) or {}
    changes = payload.get('changes', [])
    sys_msg = world.god_mode_update(changes, ai)

    if sys_msg:
        # Trigger immediate AI turn for major reality shifts
        full_input = f"[SYSTEM EVENT]\n{sys_msg}"
        thread = world.get_narrative_history()
        context_dump = world.get_context_dump()

        try:
            outcome = validate_turn_response(ai.process_turn(full_input, thread, context_dump))
        except ContractError as e:
            log_system(f"Reality-shift response rejected: {str(e)}")
            return jsonify({"response": f"Reality shift narration failed: {str(e)}", "state": get_ui_state()})

        world.apply_outcome(outcome)
        world.record_turn(full_input, outcome)

        return jsonify({
            "response": f"**REALITY SHIFT APPLIED:**\n{outcome.get('narrative', 'State updated.')}",
            "state": get_ui_state(),
            "turn_report": _turn_report_from_outcome(outcome),
        })

    return jsonify({"response": "Reality adjusted silently.", "state": get_ui_state()})

@app.route('/get_debug', methods=['GET'])
def get_debug():
    if os.path.exists("last_turn_debug.txt"):
        with open("last_turn_debug.txt", "r", encoding="utf-8") as f:
            return f.read(), 200, {"Content-Type": "application/json; charset=utf-8"}
    return jsonify({"error": "No debug info found."})

def get_ui_state():
    if not world.is_initialized(): return None
    room = world.get_current_room()
    p = world.data['player']
    inv = [world.data['items'][i]['name'] for i in p['inventory'] if i in world.data['items']]
    worn = [world.data['items'][i]['name'] for i in p['worn'] if i in world.data['items']]
    body = [world.data['items'][i]['name'] for i in p.get('body', []) if i in world.data['items']]
    return {
        "location": room.get('name', 'Unknown'),
        "inventory": inv,
        "worn": worn,
        "body": body,
        "exits": list(room.get('exits', {}).keys()),
        "total_tokens": world.data.get('meta', {}).get('total_tokens', 0),
        "pending_ambiguity": world.get_pending_ambiguity()
    }

