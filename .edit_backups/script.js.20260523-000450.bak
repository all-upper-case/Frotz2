const input = document.getElementById('cmd-input');
const log = document.getElementById('log');
const hud = document.getElementById('hud');
const term = document.getElementById('terminal');

// Settings Elements
const themeSelect = document.getElementById('theme-select');
const fontSizeRange = document.getElementById('font-size-range');

// Matrix Elements
const matrixBtn = document.getElementById('matrix-btn');
const modal = document.getElementById('god-modal');
const modalClose = document.getElementById('god-close');
const godSave = document.getElementById('god-save');
const godBody = document.getElementById('god-tbody');

// Save Manager Elements
const saveManagerBtn = document.getElementById('save-manager-btn');
const saveModal = document.getElementById('save-modal');
const saveClose = document.getElementById('save-close');
const saveList = document.getElementById('save-list');
const lorebookList = document.getElementById('lorebook-list');
const newCurrentLoreBtn = document.getElementById('new-current-lore-btn');
const newLorebookName = document.getElementById('new-lorebook-name');
const newLorebookSource = document.getElementById('new-lorebook-source');
const createLorebookBtn = document.getElementById('create-lorebook-btn');

const loreEditorModal = document.getElementById('lore-editor-modal');
const loreEditorClose = document.getElementById('lore-editor-close');
const loreEditorTitle = document.getElementById('lore-editor-title');
const loreEditorText = document.getElementById('lore-editor-text');
const loreEditorSave = document.getElementById('lore-editor-save');
const loreEditorNewGame = document.getElementById('lore-editor-new-game');
let activeLoreEditorFile = null;

const mapBtn = document.getElementById('map-btn');
const mapModal = document.getElementById('map-modal');
const mapClose = document.getElementById('map-close');
const mapCanvas = document.getElementById('map-canvas');
const mapDetails = document.getElementById('map-details');

const auditorBtn = document.getElementById('auditor-btn');
const auditorModal = document.getElementById('auditor-modal');
const auditorClose = document.getElementById('auditor-close');
const auditorLog = document.getElementById('auditor-log');
const auditorInput = document.getElementById('auditor-input');
const auditorSend = document.getElementById('auditor-send');
let auditorStarted = false;

const commandHistory = [];
let commandHistoryIndex = -1;

window.addEventListener('DOMContentLoaded', async () => {
    loadSettings();
    try {
        const res = await fetch('/get_state');
        const data = await res.json();

        if (data.response === "INITIALIZING_GENESIS") {
            appendLog("NO WORLD DATA FOUND.", 'system');
            appendLog("INITIATING GENESIS PROTOCOL...", 'system');
            triggerReset();
        } else {
            appendLog(data.response, 'system');
            if (data.state) updateHUD(data.state);
        }
    } catch(e) {
        appendLog("CONNECTION FAILED.", 'error');
    }
});

function loadSettings() {
    const s = JSON.parse(localStorage.getItem('zmachine_settings') || '{}');
    if (s.theme) {
        document.body.className = s.theme === 'clean' ? 'clean-theme' : '';
        themeSelect.value = s.theme;
    }
    if (s.fontSize) {
        document.documentElement.style.setProperty('--font-size', s.fontSize + 'px');
        fontSizeRange.value = s.fontSize;
    }
}

function saveSettings() {
    const s = {
        theme: themeSelect.value,
        fontSize: fontSizeRange.value
    };
    localStorage.setItem('zmachine_settings', JSON.stringify(s));
}

themeSelect.addEventListener('change', () => {
    document.body.className = themeSelect.value === 'clean' ? 'clean-theme' : '';
    saveSettings();
});

fontSizeRange.addEventListener('input', () => {
    document.documentElement.style.setProperty('--font-size', fontSizeRange.value + 'px');
    saveSettings();
});

// --- Game Logic ---

async function triggerReset() {
    appendLog("READING LORE... CONSTRUCTING MATTER... (PLEASE WAIT)", 'system');
    try {
        const res = await fetch('/reset', {method: 'POST'});
        const data = await res.json();

        log.innerHTML = ''; 
        appendLog(data.response || "World reset failed.", data.state ? 'system' : 'error');
        if (data.state) updateHUD(data.state);
    } catch(e) {
        appendLog("World reset failed.", 'error');
    }
}

document.getElementById('send-btn').onclick = sendCommand;
input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
        sendCommand();
        return;
    }

    if (e.key === 'ArrowUp') {
        if (commandHistory.length === 0) return;
        e.preventDefault();
        if (commandHistoryIndex < 0) commandHistoryIndex = commandHistory.length - 1;
        else commandHistoryIndex = Math.max(0, commandHistoryIndex - 1);
        input.value = commandHistory[commandHistoryIndex];
    }

    if (e.key === 'ArrowDown') {
        if (commandHistory.length === 0 || commandHistoryIndex < 0) return;
        e.preventDefault();
        commandHistoryIndex += 1;
        if (commandHistoryIndex >= commandHistory.length) {
            commandHistoryIndex = -1;
            input.value = '';
        } else {
            input.value = commandHistory[commandHistoryIndex];
        }
    }
});

document.getElementById('hud-toggle').onclick = (e) => {
    e.stopPropagation();
    hud.classList.add('open');
};

document.getElementById('hud-close').onclick = () => hud.classList.remove('open');

// Tap outside HUD to close
hud.onclick = (e) => {
    if (e.target === hud) hud.classList.remove('open');
};

// --- Save Manager Logic ---
function formatSaveDate(timestamp) {
    if (!timestamp) return 'Unknown date';
    try {
        return new Date(timestamp * 1000).toLocaleString();
    } catch(e) {
        return 'Unknown date';
    }
}

async function refreshSaveManager() {
    saveList.innerHTML = '<div class="save-empty">Loading saves...</div>';
    lorebookList.innerHTML = '<div class="save-empty">Loading lorebooks...</div>';

    try {
        const res = await fetch('/save_manager');
        const data = await res.json();

        const saves = Array.isArray(data.saves) ? data.saves : [];
        const loreBooks = Array.isArray(data.lore_books) ? data.lore_books : [];

        saveList.innerHTML = '';
        if (saves.length === 0) {
            saveList.innerHTML = '<div class="save-empty">No save files found.</div>';
        } else {
            saves.forEach(save => {
                const row = document.createElement('div');
                row.className = 'save-row';

                const info = document.createElement('div');
                info.className = 'save-info';

                const title = document.createElement('strong');
                title.textContent = `${save.current ? '▶ ' : ''}${save.world_name || save.file}`;
                info.appendChild(title);

                const meta = document.createElement('div');
                meta.className = 'save-meta';
                meta.textContent = `${save.file} | ${save.location || 'Unknown'} | ${save.total_tokens || 0} tokens | ${formatSaveDate(save.modified)}`;
                info.appendChild(meta);

                const btn = document.createElement('button');
                btn.textContent = save.current ? 'CURRENT' : 'LOAD';
                btn.disabled = !!save.current;
                btn.onclick = () => loadSaveFile(save.file);

                row.appendChild(info);
                row.appendChild(btn);
                saveList.appendChild(row);
            });
        }

        newLorebookSource.innerHTML = '<option value="">Blank structured template</option>';
        loreBooks.forEach(entry => {
            const opt = document.createElement('option');
            opt.value = entry.file;
            opt.textContent = `Copy of ${entry.file}`;
            newLorebookSource.appendChild(opt);
        });

        lorebookList.innerHTML = '';
        if (loreBooks.length === 0) {
            lorebookList.innerHTML = '<div class="save-empty">No LoreBooks entries found.</div>';
        } else {
            loreBooks.forEach(entry => {
                const row = document.createElement('div');
                row.className = 'save-row';

                const info = document.createElement('div');
                info.className = 'save-info';

                const title = document.createElement('strong');
                title.textContent = entry.file;
                info.appendChild(title);

                const meta = document.createElement('div');
                meta.className = 'save-meta';
                meta.textContent = 'Start a new game using this LoreBooks entry.';
                info.appendChild(meta);

                const actions = document.createElement('div');
                actions.className = 'save-row-actions';

                const editBtn = document.createElement('button');
                editBtn.textContent = 'EDIT';
                editBtn.onclick = () => openLoreEditor(entry.file);

                const btn = document.createElement('button');
                btn.textContent = 'NEW GAME';
                btn.onclick = () => startNewGame(entry.file);

                actions.appendChild(editBtn);
                actions.appendChild(btn);

                row.appendChild(info);
                row.appendChild(actions);
                lorebookList.appendChild(row);
            });
        }
    } catch(e) {
        saveList.innerHTML = '<div class="save-empty">Could not load save manager.</div>';
        lorebookList.innerHTML = '';
    }
}

async function loadSaveFile(file) {
    if (!confirm(`Load save "${file}"? Unsaved current changes are already stored automatically, but this will switch worlds.`)) return;

    try {
        const res = await fetch('/load_save', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({file})
        });
        const data = await res.json();

        if (data.status !== 'success') {
            appendLog(data.message || 'Load failed.', 'error');
            return;
        }

        log.innerHTML = '';
        appendLog(data.response || 'Save loaded.', 'system');
        if (data.state) updateHUD(data.state);
        saveModal.classList.add('hidden');
        hud.classList.remove('open');
    } catch(e) {
        appendLog('Load failed.', 'error');
    }
}

async function startNewGame(loreFile = null) {
    const label = loreFile ? `"${loreFile}"` : 'the current lore.txt';
    if (!confirm(`Start a new game from ${label}? The current save will be backed up/replaced according to the active world name.`)) return;

    appendLog(`STARTING NEW GAME FROM ${label}...`, 'system');

    try {
        const res = await fetch('/new_game', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify(loreFile ? {lore_file: loreFile} : {})
        });
        const data = await res.json();

        if (data.status === 'error') {
            appendLog(data.message || 'New game failed.', 'error');
            return;
        }

        log.innerHTML = '';
        appendLog(data.response || 'New game started.', data.state ? 'system' : 'error');
        if (data.state) updateHUD(data.state);
        saveModal.classList.add('hidden');
        hud.classList.remove('open');
    } catch(e) {
        appendLog('New game failed.', 'error');
    }
}

saveManagerBtn.onclick = async () => {
    saveModal.classList.remove('hidden');
    await refreshSaveManager();
};

saveClose.onclick = () => saveModal.classList.add('hidden');
saveModal.onclick = (e) => { if (e.target === saveModal) saveModal.classList.add('hidden'); };
newCurrentLoreBtn.onclick = () => startNewGame(null);

async function createLoreBook() {
    const file = newLorebookName.value.trim();
    const sourceFile = newLorebookSource.value;

    if (!file) {
        alert('Enter a file name for the new lorebook.');
        return;
    }

    try {
        const res = await fetch('/create_lorebook', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify(sourceFile ? {file, source_file: sourceFile} : {file})
        });
        const data = await res.json();

        if (data.status !== 'success') {
            alert(data.message || 'Could not create lorebook.');
            return;
        }

        newLorebookName.value = '';
        appendLog(`Created lorebook **${data.file}**. Edit it in Replit, then start a new game from it when ready.`, 'system');
        await refreshSaveManager();
    } catch(e) {
        alert('Could not create lorebook.');
    }
}

createLorebookBtn.onclick = createLoreBook;

async function openLoreEditor(file) {
    activeLoreEditorFile = file;
    loreEditorTitle.textContent = `LOREBOOK: ${file}`;
    loreEditorText.value = 'Loading...';
    loreEditorModal.classList.remove('hidden');

    try {
        const res = await fetch('/read_lorebook', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({file})
        });
        const data = await res.json();
        if (data.status !== 'success') {
            loreEditorText.value = data.message || 'Could not load lorebook.';
            return;
        }
        loreEditorText.value = data.content || '';
    } catch(e) {
        loreEditorText.value = 'Could not load lorebook.';
    }
}

async function saveActiveLorebook() {
    if (!activeLoreEditorFile) return false;

    try {
        const res = await fetch('/update_lorebook', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                file: activeLoreEditorFile,
                content: loreEditorText.value
            })
        });
        const data = await res.json();

        if (data.status !== 'success') {
            alert(data.message || 'Could not save lorebook.');
            return false;
        }

        appendLog(`Saved lorebook **${activeLoreEditorFile}**.`, 'system');
        await refreshSaveManager();
        return true;
    } catch(e) {
        alert('Could not save lorebook.');
        return false;
    }
}

loreEditorSave.onclick = saveActiveLorebook;
loreEditorNewGame.onclick = async () => {
    const saved = await saveActiveLorebook();
    if (saved && activeLoreEditorFile) {
        loreEditorModal.classList.add('hidden');
        startNewGame(activeLoreEditorFile);
    }
};
loreEditorClose.onclick = () => loreEditorModal.classList.add('hidden');
loreEditorModal.onclick = (e) => { if (e.target === loreEditorModal) loreEditorModal.classList.add('hidden'); };

function directionOffset(direction) {
    const offsets = {
        north: [0, -1],
        south: [0, 1],
        east: [1, 0],
        west: [-1, 0],
        up: [0, -1],
        down: [0, 1],
    };
    return offsets[(direction || '').toLowerCase()] || [0, 0];
}

function computeMapPositions(rooms, currentRoomId) {
    const byId = {};
    rooms.forEach(room => { byId[room.id] = room; });

    const startId = currentRoomId || (rooms[0] && rooms[0].id);
    const positions = {};
    const queue = [];

    if (startId && byId[startId]) {
        positions[startId] = {x: 0, y: 0};
        queue.push(startId);
    }

    while (queue.length > 0) {
        const rid = queue.shift();
        const room = byId[rid];
        if (!room) continue;

        Object.entries(room.exits || {}).forEach(([direction, targetId]) => {
            if (!targetId || !byId[targetId]) return;
            if (positions[targetId]) return;

            const [dx, dy] = directionOffset(direction);
            positions[targetId] = {
                x: positions[rid].x + dx,
                y: positions[rid].y + dy
            };
            queue.push(targetId);
        });
    }

    rooms.forEach((room, index) => {
        if (!positions[room.id]) {
            positions[room.id] = {x: index % 4, y: Math.floor(index / 4) + 3};
        }
    });

    return positions;
}

function renderMap(data) {
    const rooms = Array.isArray(data.rooms) ? data.rooms : [];
    const byId = {};
    rooms.forEach(room => { byId[room.id] = room; });

    const positions = computeMapPositions(rooms, data.current_room);
    const xs = Object.values(positions).map(p => p.x);
    const ys = Object.values(positions).map(p => p.y);
    const minX = Math.min(...xs, 0);
    const minY = Math.min(...ys, 0);
    const cellW = 170;
    const cellH = 110;
    const pad = 40;

    mapCanvas.innerHTML = '';
    mapDetails.textContent = 'Tap a room for details.';

    Object.entries(positions).forEach(([rid, pos]) => {
        const room = byId[rid];
        if (!room) return;

        const node = document.createElement('button');
        node.className = 'map-room';
        if (room.current) node.classList.add('current');
        if (!room.visited) node.classList.add('unvisited');

        node.style.left = `${(pos.x - minX) * cellW + pad}px`;
        node.style.top = `${(pos.y - minY) * cellH + pad}px`;

        node.innerHTML = `<strong>${room.name || 'Unknown'}</strong><span>${rid}</span>`;
        node.onclick = () => {
            const exits = Object.entries(room.exits || {})
                .map(([dir, target]) => `${dir} → ${(byId[target] && byId[target].name) || target}`)
                .join('\\n') || '(none)';
            const chars = (room.characters || []).join(', ') || '(none)';
            const items = (room.items || []).join(', ') || '(none)';
            mapDetails.textContent = `${room.name} (${room.id})\\n\\nVisited: ${room.visited ? 'yes' : 'no'}\\nCurrent: ${room.current ? 'yes' : 'no'}\\n\\nExits:\\n${exits}\\n\\nCharacters: ${chars}\\nItems: ${items}`;
        };

        mapCanvas.appendChild(node);
    });

    Object.entries(positions).forEach(([rid, pos]) => {
        const room = byId[rid];
        if (!room) return;

        Object.entries(room.exits || {}).forEach(([direction, targetId]) => {
            const targetPos = positions[targetId];
            if (!targetPos) return;

            const line = document.createElement('div');
            line.className = `map-link map-link-${direction.toLowerCase()}`;
            const x1 = (pos.x - minX) * cellW + pad + 85;
            const y1 = (pos.y - minY) * cellH + pad + 35;
            const x2 = (targetPos.x - minX) * cellW + pad + 85;
            const y2 = (targetPos.y - minY) * cellH + pad + 35;

            const left = Math.min(x1, x2);
            const top = Math.min(y1, y2);
            const width = Math.max(Math.abs(x2 - x1), 2);
            const height = Math.max(Math.abs(y2 - y1), 2);

            line.style.left = `${left}px`;
            line.style.top = `${top}px`;
            line.style.width = `${width}px`;
            line.style.height = `${height}px`;
            mapCanvas.appendChild(line);
        });
    });
}

async function openMap() {
    mapModal.classList.remove('hidden');
    mapCanvas.innerHTML = '<div class="save-empty">Loading map...</div>';

    try {
        const res = await fetch('/map_state');
        const data = await res.json();
        if (data.status !== 'success') {
            mapCanvas.innerHTML = `<div class="save-empty">${data.message || 'Could not load map.'}</div>`;
            return;
        }
        renderMap(data);
    } catch(e) {
        mapCanvas.innerHTML = '<div class="save-empty">Could not load map.</div>';
    }
}

mapBtn.onclick = openMap;
mapClose.onclick = () => mapModal.classList.add('hidden');
mapModal.onclick = (e) => { if (e.target === mapModal) mapModal.classList.add('hidden'); };

function appendAuditorMessage(text, role) {
    const div = document.createElement('div');
    div.className = `auditor-msg auditor-${role}`;
    div.innerHTML = marked.parse(text || '');
    auditorLog.appendChild(div);
    auditorLog.scrollTop = auditorLog.scrollHeight;
}

async function startAuditor() {
    auditorModal.classList.remove('hidden');

    if (auditorStarted) return;
    auditorStarted = true;
    auditorLog.innerHTML = '';
    appendAuditorMessage('Building full audit context and asking the auditor to review it...', 'system');

    try {
        const res = await fetch('/start_audit', {method: 'POST'});
        const data = await res.json();

        if (data.status !== 'success') {
            appendAuditorMessage(data.message || 'Audit failed.', 'system');
            auditorStarted = false;
            return;
        }

        appendAuditorMessage(data.response || 'No audit response returned.', 'assistant');
    } catch(e) {
        appendAuditorMessage('Audit failed.', 'system');
        auditorStarted = false;
    }
}

async function sendAuditorMessage() {
    const message = auditorInput.value.trim();
    if (!message) return;

    auditorInput.value = '';
    appendAuditorMessage(message, 'user');

    try {
        const res = await fetch('/continue_audit', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({message})
        });
        const data = await res.json();

        if (data.status !== 'success') {
            appendAuditorMessage(data.message || 'Audit chat failed.', 'system');
            return;
        }

        appendAuditorMessage(data.response || 'No response returned.', 'assistant');
    } catch(e) {
        appendAuditorMessage('Audit chat failed.', 'system');
    }
}

auditorBtn.onclick = startAuditor;
auditorClose.onclick = () => auditorModal.classList.add('hidden');
auditorModal.onclick = (e) => { if (e.target === auditorModal) auditorModal.classList.add('hidden'); };
auditorSend.onclick = sendAuditorMessage;
auditorInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') sendAuditorMessage();
});

// --- Debug Logic ---
const debugBtn = document.getElementById('debug-btn');
const debugModal = document.getElementById('debug-modal');
const debugClose = document.getElementById('debug-close');
const debugContent = document.getElementById('debug-content');

debugBtn.onclick = async () => {
    debugModal.classList.remove('hidden');
    debugContent.textContent = "Fetching debug artifacts...";
    try {
        const res = await fetch('/get_debug');
        const data = await res.json();
        if (data.error) {
            debugContent.textContent = data.error;
            return;
        }
        if (!Array.isArray(data)) {
            debugContent.textContent = "Debug payload was not in the expected format.";
            return;
        }
        
        // Find the most recent turn
        const latest = data[data.length - 1];
        if (latest) {
            let output = "";
            const raw = latest.raw_response_from_llm || {};
            const usage = raw._usage || {};
            
            output += `=== SESSION METRICS ===\n`;
            output += `Input: ${usage.input_tokens || 0} | Output: ${usage.output_tokens || 0} | Total: ${usage.total_tokens || 0}\n\n`;
            
            if (raw.reasoning_content) {
                output += `=== AI REASONING ===\n${raw.reasoning_content}\n\n`;
            }
            
            output += `=== NARRATIVE ===\n${raw.narrative || "No narrative found."}\n\n`;
            
            if (raw.state_updates && raw.state_updates.length > 0) {
                output += `=== STATE UPDATES ===\n${JSON.stringify(raw.state_updates, null, 2)}\n\n`;
            }

            output += `=== RAW JSON ===\n${JSON.stringify(raw, null, 2)}`;
            debugContent.textContent = output;
        } else {
            debugContent.textContent = "No turn data available yet.";
        }
    } catch(e) {
        debugContent.textContent = "Error loading debug info.";
    }
};
debugClose.onclick = () => debugModal.classList.add('hidden');
debugModal.onclick = (e) => { if (e.target === debugModal) debugModal.classList.add('hidden'); };

function rememberCommand(text) {
    if (!text) return;
    if (commandHistory[commandHistory.length - 1] !== text) {
        commandHistory.push(text);
        if (commandHistory.length > 50) commandHistory.shift();
    }
    commandHistoryIndex = -1;
}

async function sendCommand() {
    const text = input.value.trim();
    if (!text) return;
    rememberCommand(text);

    if (text === '/reset') {
        if(confirm("Wipe world and regenerate from Lore?")) triggerReset();
        input.value = '';
        return;
    }

    if (text === '/models') {
        appendLog("> /models", 'user');
        input.value = '';
        try {
            const res = await fetch('/models');
            const data = await res.json();
            if (!Array.isArray(data) || data.length === 0) {
                appendLog("No Venice models are available. Check the API key and try again.", 'error');
                return;
            }
            let msg = "### AVAILABLE VENICE MODELS\n\n";
            data.forEach(m => {
                const reasoning = m.reasoning ? "Reasoning Support" : "";
                const pricePrompt = m.pricing && m.pricing.prompt ? (parseFloat(m.pricing.prompt) * 1000000).toFixed(2) : "?";
                const priceComp = m.pricing && m.pricing.completion ? (parseFloat(m.pricing.completion) * 1000000).toFixed(2) : "?";
                const contextWindow = Number.isFinite(m.context_window) ? m.context_window.toLocaleString() : m.context_window;
                
                msg += `- **${m.id}**\n  *${m.name}*\n  Context: ${contextWindow} tokens | ${reasoning}\n  Pricing: ${pricePrompt}/1M input, ${priceComp}/1M output\n\n`;
            });
            msg += "Type `/model [ID]` to switch.";
            appendLog(msg, 'system');
        } catch(e) { appendLog("Failed to fetch models.", 'error'); }
        return;
    }

    if (text.startsWith('/model ')) {
        const m = text.split(' ')[1];
        appendLog(`> /model ${m}`, 'user');
        input.value = '';
        try {
            const res = await fetch('/set_model', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({model: m})
            });
            const data = await res.json();
            if (data.status === 'success') {
                appendLog(`Model switched to **${m}**.`, 'system');
            } else {
                appendLog("Failed to switch model.", 'error');
            }
        } catch(e) { appendLog("Failed to switch model.", 'error'); }
        return;
    }

    appendLog(`> ${text}`, 'user');
    input.value = '';

    try {
        const res = await fetch('/command', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({input: text})
        });
        const data = await res.json();

        appendLog(data.response || "No response returned.", data.state ? 'ai' : 'error');
        appendTurnReport(data.turn_report);
        if (data.state) updateHUD(data.state);
    } catch (e) {
        appendLog("Communication Error.", 'error');
    }
}

function appendLog(html, type) {
    const div = document.createElement('div');
    div.className = `msg ${type}`;
    div.innerHTML = marked.parse(html || "");
    log.appendChild(div);
    term.scrollTop = term.scrollHeight;
}

function appendTurnReport(report) {
    if (!report) return;
    const warnings = Array.isArray(report.warnings) ? report.warnings : [];
    const toolResults = Array.isArray(report.tool_results) ? report.tool_results : [];
    const pending = report.pending_ambiguity;

    if (warnings.length === 0 && toolResults.length === 0 && !pending) return;

    const details = document.createElement('details');
    details.className = 'msg system';

    const summary = document.createElement('summary');
    summary.textContent = warnings.length > 0 ? `Turn report (${warnings.length} warning${warnings.length === 1 ? '' : 's'})` : 'Turn report';
    details.appendChild(summary);

    const pre = document.createElement('pre');
    pre.style.whiteSpace = 'pre-wrap';
    pre.textContent = JSON.stringify(report, null, 2);
    details.appendChild(pre);

    log.appendChild(details);
    term.scrollTop = term.scrollHeight;
}

function updateHUD(state) {
    document.getElementById('stat-loc').textContent = state.location;
    document.getElementById('stat-exits').textContent = state.exits.join(', ').toUpperCase();
    document.getElementById('stat-tokens').textContent = `Total Session Tokens: ${state.total_tokens || 0}`;

    const ul = document.getElementById('stat-inv');
    ul.innerHTML = '';

    if (state.pending_ambiguity) {
        const hAmb = document.createElement('li');
        hAmb.innerHTML = '<strong style="color:var(--accent-color); font-size:0.85em;">[PENDING CHOICE]</strong>';
        ul.appendChild(hAmb);

        const li = document.createElement('li');
        li.textContent = state.pending_ambiguity.query || 'ambiguous reference';
        ul.appendChild(li);

        const spacer = document.createElement('li');
        spacer.style.height = '10px';
        ul.appendChild(spacer);
    }

    if (state.body && state.body.length > 0) {
        const hBody = document.createElement('li');
        hBody.innerHTML = '<strong style="color:var(--dim-color); font-size:0.85em;">[BODY]</strong>';
        ul.appendChild(hBody);
        state.body.forEach(i => {
            const li = document.createElement('li');
            li.textContent = i;
            ul.appendChild(li);
        });
        const spacer = document.createElement('li');
        spacer.style.height = '10px';
        ul.appendChild(spacer);
    }

    if (state.worn && state.worn.length > 0) {
        const hWorn = document.createElement('li');
        hWorn.innerHTML = '<strong style="color:var(--dim-color); font-size:0.85em;">[WORN]</strong>';
        ul.appendChild(hWorn);
        state.worn.forEach(i => {
            const li = document.createElement('li');
            li.textContent = i;
            ul.appendChild(li);
        });
        const spacer = document.createElement('li');
        spacer.style.height = '10px';
        ul.appendChild(spacer);
    }

    if (state.inventory && state.inventory.length > 0) {
        const hInv = document.createElement('li');
        hInv.innerHTML = '<strong style="color:var(--dim-color); font-size:0.85em;">[CARRIED]</strong>';
        ul.appendChild(hInv);
        state.inventory.forEach(i => {
            const li = document.createElement('li');
            li.textContent = i;
            ul.appendChild(li);
        });
    } else {
        const li = document.createElement('li');
        li.textContent = '(Empty)';
        li.style.color = '#555';
        ul.appendChild(li);
    }
}

// --- MATRIX LOGIC ---

matrixBtn.onclick = async () => {
    modal.classList.remove('hidden');
    godBody.innerHTML = '<tr><td colspan="4">Loading Reality...</td></tr>';

    try {
        const res = await fetch('/get_god_state');
        const data = await res.json();
        renderMatrix(data);
    } catch(e) {
        godBody.innerHTML = '<tr><td colspan="4">Could not load reality state.</td></tr>';
    }
};

modalClose.onclick = () => modal.classList.add('hidden');

function appendLabeledInput(container, labelText, className, value, multiline = false) {
    const wrapper = document.createElement('div');
    wrapper.style.marginTop = '5px';

    const label = document.createElement('strong');
    label.textContent = labelText;
    wrapper.appendChild(label);
    wrapper.appendChild(document.createTextNode(' '));

    const field = multiline ? document.createElement('textarea') : document.createElement('input');
    field.className = className;
    field.value = value || '';
    if (multiline) {
        field.style.width = '100%';
        field.style.height = '60px';
        field.style.background = '#222';
        field.style.color = '#0f0';
        field.style.border = '1px solid #444';
    } else {
        field.type = 'text';
    }

    wrapper.appendChild(field);
    container.appendChild(wrapper);
}

function renderMatrix(data) {
    godBody.innerHTML = '';
    const items = Array.isArray(data.items) ? data.items : [];
    const rooms = Array.isArray(data.rooms) ? data.rooms : [];

    if (items.length === 0) {
        godBody.innerHTML = '<tr><td colspan="4">No items found in the current world.</td></tr>';
        return;
    }

    items.forEach(item => {
        // Main Row
        const tr = document.createElement('tr');
        tr.dataset.id = item.id;
        tr.dataset.origAliases = item.aliases || '';
        tr.dataset.origDesc = item.description || '';

        const tdName = document.createElement('td');
        tdName.textContent = item.name || '(unnamed item)';
        tr.appendChild(tdName);

        const tdLoc = document.createElement('td');
        tdLoc.textContent = item.location || 'Unknown';
        tr.appendChild(tdLoc);

        const tdNew = document.createElement('td');
        const sel = document.createElement('select');
        ['(Unchanged)', 'Inventory', 'Worn', 'Body', 'Void'].forEach(opt => {
            const o = document.createElement('option');
            o.value = opt; o.textContent = opt;
            sel.appendChild(o);
        });
        rooms.forEach(r => {
            const o = document.createElement('option');
            o.value = r.id; 
            o.textContent = `Room: ${r.name}`;
            sel.appendChild(o);
        });
        tdNew.appendChild(sel);
        tr.appendChild(tdNew);

        // Details Button
        const tdBtn = document.createElement('td');
        const btn = document.createElement('button');
        btn.textContent = "DETAILS";
        btn.style.fontSize = "0.8em";
        btn.onclick = () => {
            const nextRow = tr.nextElementSibling;
            nextRow.classList.toggle('hidden');
        };
        tdBtn.appendChild(btn);
        tr.appendChild(tdBtn);

        godBody.appendChild(tr);

        // Details Row
        const trDet = document.createElement('tr');
        trDet.className = "details-row hidden";
        trDet.dataset.parent = item.id;

        const tdDet = document.createElement('td');
        tdDet.colSpan = 4;

        const divDet = document.createElement('div');
        divDet.style.padding = "10px";
        divDet.style.background = "#080808";

        appendLabeledInput(divDet, 'Aliases:', 'edit-aliases', item.aliases || '');
        appendLabeledInput(divDet, 'Description:', 'edit-desc', item.description || '', true);
        appendLabeledInput(divDet, 'Auto-Fix (AI):', 'fix-prompt', '');

        tdDet.appendChild(divDet);
        trDet.appendChild(tdDet);
        godBody.appendChild(trDet);
    });
}

godSave.onclick = async () => {
    const changes = [];
    const rows = godBody.querySelectorAll('tr[data-id]');

    rows.forEach(row => {
        const id = row.dataset.id;
        const sel = row.querySelector('select');
        const nextRow = row.nextElementSibling;

        const aliasesInp = nextRow.querySelector('.edit-aliases');
        const descInp = nextRow.querySelector('.edit-desc');
        const fixInp = nextRow.querySelector('.fix-prompt');

        // Collect changes
        const change = { id: id };
        let hasChange = false;

        if (sel.value !== '(Unchanged)') {
            change.newLocation = sel.value;
            hasChange = true;
        }

        // Check for manual edits
        if (aliasesInp.value !== row.dataset.origAliases) {
            change.newAliases = aliasesInp.value;
            hasChange = true;
        }
        if (descInp.value !== row.dataset.origDesc) {
            change.newDescription = descInp.value;
            hasChange = true;
        }

        if (fixInp.value.trim() !== '') {
            change.fixInstruction = fixInp.value.trim();
            hasChange = true;
        }

        if (hasChange) {
            changes.push(change);
        }
    });

    if (changes.length === 0) {
        modal.classList.add('hidden');
        return;
    }

    godSave.textContent = "PATCHING REALITY...";
    try {
        const res = await fetch('/god_update', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({changes})
        });
        const data = await res.json();

        appendLog(data.response || "Reality patch completed.", data.state ? 'system' : 'error');
        appendTurnReport(data.turn_report);
        if (data.state) updateHUD(data.state);

        godSave.textContent = "APPLY REALITY PATCH";
        modal.classList.add('hidden');
    } catch(e) {
        alert("Patch Failed.");
        godSave.textContent = "APPLY REALITY PATCH";
    }
};

if (typeof marked === 'undefined') window.marked = { parse: (t) => t };
